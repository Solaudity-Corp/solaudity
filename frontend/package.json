{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "panda:codegen": "panda codegen",
    "panda:css": "panda cssgen",
    "panda:codegen:watch": "panda codegen --watch",
    "panda:css:watch": "panda cssgen --watch",
    "panda:generate": "npm run panda:codegen && npm run panda:css",
    "predev": "npm run panda:generate",
    "dev": "vite",
    "prebuild": "npm run panda:generate",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/roboto-mono": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@types/marked": "^5.0.2",
    "@viz-js/viz": "^3.28.0",
    "@xyflow/react": "^12.11.2",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.11.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.563.0",
    "marked": "^18.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "dompurify": "3.4.2",
    "hono": ">=4.12.16",
    "ip-address": ">=10.1.1",
    "@pandacss/postcss": {
      "postcss": ">=8.5.10"
    },
    "@pandacss/node": {
      "postcss": ">=8.5.10"
    },
    "@pandacss/generator": {
      "postcss": ">=8.5.10"
    },
    "@pandacss/core": {
      "postcss": ">=8.5.10"
    },
    "picomatch": "4.0.4",
    "micromatch": {
      "picomatch": "2.3.2"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@pandacss/dev": "^1.11.4",
    "@pandacss/postcss": "^1.8.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
